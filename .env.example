# Local development (PostgreSQL)
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173,http://localhost:5500,http://127.0.0.1:5173
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/matrimonial
SEED_ON_STARTUP=true
TRUST_PROXY=false
DB_SSL=false

# --- AWS ECS (production) — Task Definition environment ---
# PORT=3001
# HOST=0.0.0.0
# NODE_ENV=production
# JWT_SECRET=<from Secrets Manager>
# JWT_EXPIRES_IN=7d
# CORS_ORIGIN=https://your-cloudfront-domain.cloudfront.net
# DATABASE_URL=postgresql://USER:PASS@your-rds-endpoint.region.rds.amazonaws.com:5432/matrimonial
# SEED_ON_STARTUP=false
# TRUST_PROXY=true
# DB_SSL=true
